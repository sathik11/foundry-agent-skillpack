# infra/baseline.env — copy to baseline.env and fill in. Sourced by baseline.sh.
# MAINTAINER/CI-ONLY. Do NOT commit a real baseline.env with secrets (it's gitignored).

# --- required ---
export AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export AZURE_LOCATION="eastus2"                 # must be in main.bicep @allowed list
export AZURE_ENV_NAME="skillpack-e2e"
export AZURE_RESOURCE_GROUP="rg-skillpack-e2e"  # dedicated, isolated RG

# --- optional ---
# Object ID to grant Foundry data-plane roles. Auto-resolved from the login if omitted.
# export AZURE_PRINCIPAL_ID=""

# Standing-baseline toggles (defaults shown). APIM Developer cold-provision ~45 min.
export ENABLE_APIM="true"
export APIM_SKU_NAME="Developer"
export ENABLE_SEARCH="true"
export ENABLE_COSMOS="true"
export ENABLE_STORAGE="true"
export ENABLE_MONITORING="true"
export ENABLE_HOSTED_AGENTS="true"

# Model deployment(s) for the AGENT-UNDER-TEST (NOT the driver brain — that GPT-5.4
# deployment lives in a separate RG and is referenced by the driver, see W3).
# JSON array per main.bicep schema, e.g.:
# export AI_PROJECT_DEPLOYMENTS='[{"name":"gpt-4o-mini","model":{"format":"OpenAI","name":"gpt-4o-mini","version":"2024-07-18"},"sku":{"name":"GlobalStandard","capacity":50}}]'
export AI_PROJECT_DEPLOYMENTS="[]"
