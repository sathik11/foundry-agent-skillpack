# yaml-language-server: $schema=https://raw.githubusercontent.com/microsoft/AgentSchema/refs/heads/main/schemas/v1.0/AgentManifest.yaml
# AgentManifest for the agent-framework (default) hosted path — consumed by `azd ai agent init -m`.
# Sibling of agent.yaml (ContainerAgent, informational). This is the schema safe-azd-init.sh passes
# to `azd ai agent init --manifest`. Mirrors templates/langgraph-byo/agent.manifest.yaml.template
# for parity (the langgraph path shipped this; the agent-framework path was missing it — see the
# foundry-deploy scaffold.md file map). `/plan-agent` Track B substitutes the ${...} placeholders.
name: ${AGENT_NAME}
displayName: "${AGENT_NAME} (agent-framework, Responses)"
description: >
  ${AGENT_DESCRIPTION}
metadata:
  tags:
    - AI Agent Hosting
    - Responses Protocol
    - agent-framework
    - Python
template:
  name: ${AGENT_NAME}
  kind: hosted
  protocols:
    - protocol: responses
      version: 1.0.0
  environment_variables:
    # FOUNDRY_PROJECT_ENDPOINT and APPLICATIONINSIGHTS_CONNECTION_STRING are injected by the
    # platform (hosted) and translated by azd (local). Do NOT declare them here.
    - name: AZURE_AI_MODEL_DEPLOYMENT_NAME
      value: "{{AZURE_AI_MODEL_DEPLOYMENT_NAME}}"
resources:
  - kind: model
    id: ${MODEL_ID}              # e.g. gpt-4o-mini
    name: AZURE_AI_MODEL_DEPLOYMENT_NAME
