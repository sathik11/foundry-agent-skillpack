# yaml-language-server: $schema=https://raw.githubusercontent.com/microsoft/AgentSchema/refs/heads/main/schemas/v1.0/AgentManifest.yaml
name: ${AGENT_NAME}
displayName: "${AGENT_NAME} (LangGraph BYO, Responses)"
description: >
  ${AGENT_DESCRIPTION}
metadata:
  tags:
    - AI Agent Hosting
    - Responses Protocol
    - Bring Your Own
    - LangGraph
    - Python
template:
  name: ${AGENT_NAME}
  kind: hosted
  protocols:
    - protocol: responses
      version: 1.0.0
  environment_variables:
    # FOUNDRY_PROJECT_ENDPOINT and APPLICATIONINSIGHTS_CONNECTION_STRING are
    # injected by the platform (hosted) and translated by azd (local). Do NOT
    # declare them here.
    - name: AZURE_AI_MODEL_DEPLOYMENT_NAME
      value: "{{AZURE_AI_MODEL_DEPLOYMENT_NAME}}"
resources:
  - kind: model
    id: ${MODEL_ID}              # e.g. gpt-4.1-mini
    name: AZURE_AI_MODEL_DEPLOYMENT_NAME
