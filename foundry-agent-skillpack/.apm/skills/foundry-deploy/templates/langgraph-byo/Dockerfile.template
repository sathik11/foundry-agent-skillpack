# Use the platform-supported base. linux/amd64 is required (ACR remote build
# handles this; local builds on Apple Silicon need --platform=linux/amd64).
FROM python:3.12-slim

WORKDIR /app
COPY . user_agent/
WORKDIR /app/user_agent

RUN pip install --upgrade pip \
 && if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

# Foundry hosted agents expose port 8088.
EXPOSE 8088

CMD ["python", "main.py"]
