FROM python:3.12-slim

WORKDIR /app

# Build hygiene: pin pip, no cache, no .pyc bloat
ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY . .

EXPOSE 8088
CMD ["python", "main.py"]
